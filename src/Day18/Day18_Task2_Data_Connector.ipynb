   "source": [
    "import sqlite3\n",
    "import pandas as pd\n",
    "conn = sqlite3.connect(\"Day18_Internship.db\")\n",
    "query = \"\"\"\n",
    "SELECT \n",
    "    interns.name,\n",
    "    interns.track,\n",
    "    mentors.mentor_name\n",
    "FROM interns\n",
    "INNER JOIN mentors\n",
    "ON interns.track = mentors.track;\n",
    "\"\"\"\n",
    "df = pd.read_sql_query(query, conn)\n",
    "df"
   ]
  },
